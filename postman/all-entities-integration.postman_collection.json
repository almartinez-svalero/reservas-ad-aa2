          "raw": "{{baseUrl}}/api/restaurantes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "restaurantes"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Restaurante Integracion\",\n  \"direccion\": \"Calle Testing 1, Zaragoza\",\n  \"telefono\": \"+34976000999\",\n  \"aforoMaximo\": 90,\n  \"valoracionMedia\": 4.6,\n  \"activo\": true,\n  \"fechaApertura\": \"2022-01-10\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Estado 201 Created', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('restauranteId', body.id);",
              "pm.test('Restaurante creado con estructura y valores correctos', function () {",
              "  pm.expect(body).to.include.keys('id','nombre','direccion','telefono','aforoMaximo','valoracionMedia','activo','fechaApertura');",
              "  pm.expect(body.nombre).to.eql('Restaurante Integracion');",
              "  pm.expect(body.activo).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
