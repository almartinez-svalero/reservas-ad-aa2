{
  "info": {
    "name": "Reservas API - All Entities Integration Tests",
    "description": "Tests de integracion para todas las entidades de la API con JWT automatico.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "apiKey",
      "value": ""
    },
    {
      "key": "jwtUsername",
      "value": "admin"
    },
    {
      "key": "jwtPassword",
      "value": "admin123"
    },
    {
      "key": "jwtToken",
      "value": ""
    },
    {
      "key": "restauranteId",
      "value": ""
    },
    {
      "key": "clienteId",
      "value": ""
    },
    {
      "key": "mesaId",
      "value": ""
    },
    {
      "key": "empleadoId",
      "value": ""
    },
    {
      "key": "reservaId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "POST login JWT",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Estado 200 OK', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('jwtToken', body.accessToken);",
              "pm.test('La respuesta contiene token JWT', function () {",
              "  pm.expect(body.tokenType).to.eql('Bearer');",
              "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{jwtUsername}}\",\n  \"password\": \"{{jwtPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "POST crear restaurante",
      "request": {
        "method": "POST",
